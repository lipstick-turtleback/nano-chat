{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn",
        "useExhaustiveDependencies": "warn",
        "noUnreachable": "error",
        "noUndeclaredVariables": "error"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noAssignInExpressions": "warn",
        "noDoubleEquals": "warn",
        "noShadowRestrictedNames": "error",
        "noArrayIndexKey": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useConst": "warn",
        "useTemplate": "warn",
        "noUselessElse": "warn",
        "useImportType": "warn",
        "useNodejsImportProtocol": "warn"
      },
      "complexity": {
        "noForEach": "off",
        "noBannedTypes": "warn",
        "noStaticOnlyClass": "warn",
        "noUselessConstructor": "warn"
      },
      "performance": {
        "noDelete": "warn",
        "noAccumulatingSpread": "warn"
      },
      "a11y": {
        "useKeyWithClickEvents": "off",
        "useSemanticElements": "off",
        "useButtonType": "warn",
        "noSvgWithoutTitle": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "none",
      "arrowParentheses": "always",
      "semicolons": "always",
      "indentStyle": "space",
      "indentWidth": 2
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": false
    },
    "globals": [
      "LanguageModel",
      "chrome",
      "jest",
      "describe",
      "it",
      "expect",
      "beforeAll",
      "test",
      "globalThis"
    ]
  },
  "json": {
    "formatter": {
      "trailingCommas": "none",
      "indentStyle": "space",
      "indentWidth": 2
    }
  },
  "css": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "quoteStyle": "single"
    },
    "linter": {
      "enabled": false
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": ["src/**/*.{js,jsx}", "e2e/**/*.{js}", "*.{js,jsx,json}", "src/**/*.css"]
  }
}
